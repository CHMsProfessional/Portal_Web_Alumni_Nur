POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
ACCESS_DB_NAME=AlumniDBAccess
CONTENT_DB_NAME=AlumniDB

# Shared Django settings (used by both APIs in docker-compose.yml)
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_ORIGINS=http://localhost:8080

# Optional: override allowed hosts per API
ACCESS_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,access-api
CONTENT_DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,content-api

# Optional: email settings used by AlumniAPI
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Optional: Redis settings (mostly relevant to ContenidoAlumniApi)
REDIS_PASSWORD=
REDIS_USE_SSL=False
REDIS_CACHE_DB=1
REDIS_CHANNEL_DB=0

FRONTEND_PUBLIC_PORT=8080
ACCESS_PUBLIC_PORT=8000
CONTENT_PUBLIC_PORT=8001

# Internal ports (rarely needed to change)
ACCESS_PORT=8000
CONTENT_PORT=8001

FRONTEND_VITE_API_BASE=http://localhost:8001/api
FRONTEND_VITE_API_ACCESS_URL=http://localhost:8000/api/
FRONTEND_VITE_API_CONTENT_URL=http://localhost:8001/api/
FRONTEND_VITE_WS_CONTENT_URL=ws://localhost:8001
FRONTEND_VITE_CONTENT_MEDIA_URL=http://localhost:8001
FRONTEND_VITE_ACCESS_MEDIA_URL=http://localhost:8000
