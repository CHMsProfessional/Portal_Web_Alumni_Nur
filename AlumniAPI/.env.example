EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=change-me@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=change-me@example.com

DJANGO_SECRET_KEY=change-me
