# Default URLs when running the stack with `docker compose` (repo root)
VITE_API_BASE=http://localhost:8901/api
VITE_API_ACCESS_URL=http://localhost:8900/api/
VITE_API_CONTENT_URL=http://localhost:8901/api/
VITE_WS_CONTENT_URL=ws://localhost:8901
VITE_CONTENT_MEDIA_URL=http://localhost:8901
VITE_ACCESS_MEDIA_URL=http://localhost:8900

# If you run the Django APIs directly on your machine (without docker), you can switch to:
# Access API: 8000, Content API: 8001
# VITE_API_ACCESS_URL=http://localhost:8000/api/
# VITE_API_CONTENT_URL=http://localhost:8001/api/
# VITE_WS_CONTENT_URL=ws://localhost:8001
# VITE_CONTENT_MEDIA_URL=http://localhost:8001
# VITE_ACCESS_MEDIA_URL=http://localhost:8000
